# --- Free-tier minimum (Groq + Sarvam + OCR.space) ---
# Groq covers Whisper STT + LLM translation. Free, no credit card.
# https://console.groq.com/keys
GROQ_API_KEY=

# Sarvam Bulbul TTS — native Indian-language voiceovers. Free trial credits.
# https://dashboard.sarvam.ai
SARVAM_API_KEY=

# OCR.space free tier: 25k requests/month.
# https://ocr.space/ocrapi/freekey
OCR_SPACE_API_KEY=

# --- Optional paid upgrades (auto-detected if set) ---
# If set, translation uses Claude Sonnet 4.6 instead of Groq Llama 3.3.
CLAUDE_API_KEY=
# If set without GROQ_API_KEY, OpenAI Whisper + GPT-4o are used.
OPENAI_API_KEY=
# If set, Google Vision DOCUMENT_TEXT_DETECTION is used instead of OCR.space.
GOOGLE_VISION_API_KEY=
# Legacy — pre-Sarvam ElevenLabs TTS. Not used by default anymore.
ELEVENLABS_API_KEY=

# --- App config ---
STORAGE_DIR=./storage
DB_URL=sqlite:///./adlocalizer.db
MAX_UPLOAD_MB=200
MAX_VIDEO_DURATION_S=60
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
